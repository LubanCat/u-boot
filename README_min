into many parts:
bl31_0x00040000.bin
bl31_0x00040000.bin.digest (sha256)
bl31_0x00040000.bin.gz     (gzip -kf9 bl31_0x00040000.bin)
bl31_0x0005a000.bin
bl31_0x0005c000.bin
bl31_0xfdcc1000.bin
bl31_0xfdcce000.bin
bl31_0xfdcd0000.bin


