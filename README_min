put board into maskrom mode 
sudo ./rkdeveloptool db ../../bootloader/u-boot/rk356x_spl_loader_v1.23.114.bin 
sudo ./rkdeveloptool cs 1
sudo ./rkdeveloptool ul ../../bootloader/u-boot/rk356x_spl_loader_v1.23.114.bin 
sudo ./rkdeveloptool gpt ../../bootloader/parameter.txt
sudo ./rkdeveloptool wlx uboot ../../bootloader/u-boot/uboot.img

